# =============================================================================
# Aireq — example environment file
# Copy to .env.local (never commit) and fill in real values from your providers.
# =============================================================================

# ---------- Database (Neon Postgres) -----------------------------------------
# From https://console.neon.tech → your project → Connection details → "Pooled connection"
# Always use sslmode=require with Neon.
DATABASE_URL_DEV=postgresql://USER:PASS@HOST.neon.tech/aireq_dev?sslmode=require&channel_binding=require
DATABASE_URL_PROD=postgresql://USER:PASS@HOST.neon.tech/aireq_prod?sslmode=require&channel_binding=require

# ---------- API ---------------------------------------------------------------
# Port 5180 chosen because 5080 collides with QuantamAnalytics on some Macs.
ASPNETCORE_ENVIRONMENT=Development
API__PORT=5180
API__PUBLIC_URL=http://localhost:5180

# ---------- Web ---------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5180
NEXT_PUBLIC_BRAND=Aireq

# ---------- Auth (JWT) --------------------------------------------------------
# Generate with: openssl rand -base64 48
JWT__SIGNING_KEY=replace-me-32-byte-min-random-base64
JWT__ISSUER=aireq
JWT__AUDIENCE=aireq-web
JWT__LIFETIME_MINUTES=60

# ---------- LLM ---------------------------------------------------------------
# Provider selection. 'groq' = free MVP default (Llama 3.1 8B on Groq's free
# tier, 30 req/min, 6000 req/day). 'anthropic' = paid Claude Haiku / Sonnet,
# flip once paying customers cover the bill.
LLM__PROVIDER=groq

# Groq (https://console.groq.com → API Keys — free)
GROQ_API_KEY=gsk_REPLACE_ME
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_STRONG=llama-3.3-70b-versatile

# Anthropic Claude (https://console.anthropic.com → API Keys — paid)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MAX_MONTHLY_USD=20
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_STRONG=claude-sonnet-4-6

# ---------- Embeddings (Google Gemini — free) --------------------------------
# Free key from https://aistudio.google.com/apikey. text-embedding-004 = 768-dim.
# The 768 dimension is baked into the pgvector columns; changing models to a
# different dimension requires a migration (see EmbeddingConfig.Dimensions).
GEMINI_API_KEY=REPLACE_ME
GEMINI_EMBEDDING_MODEL=text-embedding-004
# Embedding pass cadence + batch size (optional; defaults in code).
# EMBEDDING__CRON=15 * * * *
# EMBEDDING__BATCHSIZE=100

# ---------- Email --------------------------------------------------------------
# https://resend.com → API Keys. Cold-apply emails (Tier C), follow-ups, and
# digests all go through here. Sends are DRY-RUN until live submit is enabled
# AND a real key is set. Warmup cap protects a new sending domain's reputation.
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM=Aireq <noreply@aireq.com>
# EMAIL__DAILYCAP=50      # max real sends per tenant per UTC day (warmup)

# Gmail API (one shared OAuth app credential; each tenant connects their own
# mailbox). Used by BOTH the API (connect/callback flow) and the worker (inbound
# reply polling). The integration self-disables until these are real values.
#   1. Google Cloud console -> OAuth consent screen + credentials (Web app).
#   2. Add the redirect URI below as an Authorized redirect URI.
#   3. Scope needed: https://www.googleapis.com/auth/gmail.readonly
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
# Must EXACTLY match an Authorized redirect URI in the Google console.
# GOOGLE__REDIRECTURI=http://localhost:5080/api/integrations/gmail/callback
# Where the browser lands after a successful connect (the web app).
# GOOGLE__POSTCONNECTREDIRECT=http://localhost:3000/settings/integrations?gmail=connected

# Inbound reply poller (AIRMVP1-401). Polls every connected mailbox on this cron.
# GMAIL_INBOUND__CRON=*/5 * * * *      # every 5 minutes
# GMAIL_INBOUND__MAXPERPOLL=50         # messages fetched per mailbox per poll
# GMAIL_INBOUND__INITIALSCANDAYS=3     # first-poll inbox lookback window

# Reply classifier + escalation (AIRMVP1-402). Haiku-classifies each new reply.
# REPLY_CLASSIFICATION__CRON=*/5 * * * *   # every 5 minutes, just behind the poll
# REPLY_CLASSIFICATION__BATCHSIZE=25       # threads classified per pass
# REPLY_CLASSIFICATION__MAXBODYCHARS=4000  # reply body clamp before the model

# ---------- Storage (Azure Blob — Azurite locally) ---------------------------
# Default Azurite connection string for local dev.
AZURE_BLOB_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_BLOB_CONTAINER_RESUMES=resumes

# ---------- Job-source APIs --------------------------------------------------
# Each source self-disables while its key is the REPLACE_ME placeholder, so you
# can enable them one at a time. Ingestion runs every enabled source.

# Adzuna (https://developer.adzuna.com — free, ~1k calls/mo)
ADZUNA_APP_ID=REPLACE_ME
ADZUNA_APP_KEY=REPLACE_ME
ADZUNA_COUNTRY=us

# USAJobs (https://developer.usajobs.gov — free; USER_AGENT must be your email)
USAJOBS_USER_AGENT=REPLACE_ME
USAJOBS_AUTH_KEY=REPLACE_ME

# Ingestion schedule + scope (optional overrides; sane defaults in code).
# JOB_INGESTION__CRON=0 */6 * * *
# JOB_INGESTION__MAXRESULTSPERQUERY=50
# JOB_INGESTION__LOCATION=

# ATS boards (keyless, freshest source — straight from the employer's ATS).
# Curated starter lists ship in code; override with your own company tokens.
# Unknown/stale tokens just 404 and skip, so it's safe to add speculatively.
# Use indexed keys to override the list, e.g.:
# JOB_INGESTION__ATS__GREENHOUSE__0=stripe
# JOB_INGESTION__ATS__GREENHOUSE__1=airbnb
# JOB_INGESTION__ATS__LEVER__0=netflix
# JOB_INGESTION__ATS__ASHBY__0=ramp

# Dedupe + freshness maintenance (optional overrides; defaults in code).
# JOB_MAINTENANCE__CRON=30 */12 * * *
# JOB_MAINTENANCE__STALENESSWINDOWHOURS=72
# JOB_MAINTENANCE__DEDUPEWINDOWDAYS=30

# ---------- Observability ----------------------------------------------------
SERILOG__MINIMUMLEVEL__DEFAULT=Information
SENTRY_DSN=

# ---------- Feature flags ----------------------------------------------------
FEATURES__AUTO_APPLY_REQUIRE_APPROVAL=true
FEATURES__DAILY_AUTO_APPLY_CAP=10
FEATURES__SEND_EMAILS_WITHOUT_APPROVAL=false
# Master safety switch for Tier A submissions. FALSE = dry-run (builds + logs
# + records the application but sends nothing to any employer). Flip to true
# ONLY when you've verified the flow against a real board you intend to apply to.
FEATURES__ENABLE_LIVE_SUBMIT=false
# Optional Greenhouse board API key (HTTP Basic) for boards that require auth
# to accept applications. Public boards don't need it.
GREENHOUSE_BOARD_KEY=REPLACE_ME
