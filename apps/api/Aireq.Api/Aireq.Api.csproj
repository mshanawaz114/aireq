<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Aireq.Api</RootNamespace>
    <AssemblyName>Aireq.Api</AssemblyName>
    <UserSecretsId>aireq-api-dev</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\packages\shared\Aireq.Shared\Aireq.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Web / OpenAPI -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />

    <!-- Auth -->
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />

    <!-- Persistence -->
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <PackageReference Include="Pgvector.EntityFrameworkCore" />

    <!-- Background jobs (client only — the worker hosts the server). -->
    <PackageReference Include="Hangfire.AspNetCore" />
    <PackageReference Include="Hangfire.PostgreSql" />

    <!-- Object storage (resumes, tailored resumes). -->
    <PackageReference Include="Azure.Storage.Blobs" />

    <!-- Health -->
    <PackageReference Include="AspNetCore.HealthChecks.NpgSql" />

    <!-- Logging -->
    <PackageReference Include="Serilog.AspNetCore" />
    <PackageReference Include="Serilog.Sinks.Console" />
    <PackageReference Include="Serilog.Sinks.Async" />

    <!-- Resilience -->
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />

    <!-- .env.local loader (dev convenience) -->
    <PackageReference Include="DotNetEnv" />
  </ItemGroup>

</Project>
